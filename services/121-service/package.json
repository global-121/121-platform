{
  "name": "121-service",
  "author": "121.global",
  "homepage": "https://121.global/",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/global-121/121-platform.git",
    "directory": "services/121-service"
  },
  "main": "index.js",
  "scripts": {
    "prepare": "npm install --legacy-peer-deps=false --prefix=../../packages/eslint-config-121-platform/",
    "install:dependencies-for-portal": "npm install",
    "lint": "eslint \"**/*.{ts,js,mjs}\" --cache",
    "fix": "npm run lint -- --fix",
    "build": "nest build --path=tsconfig.json",
    "start": "GLOBAL_121_VERSION=$(test -f \"VERSION.txt\" && cat VERSION.txt || echo $GLOBAL_121_VERSION)  node dist/main.js",
    "start:dev": "nodemon --config nodemon.json --watch src/**/*.json --watch src/**/*.csv --exec npm run start:dev:nest",
    "start:dev:collect-coverage": "./node_modules/.bin/nyc npm run start:dev:nest",
    "start:dev:nest": "nest start --require=tsconfig-paths/register --debug=0.0.0.0:9229 --watch --path=tsconfig.json",
    "prestart:dev": "npm install --no-save",
    "prestart:dev:collect-coverage": "npm install --no-save",
    "seed:dev": "ts-node --require=tsconfig-paths/register src/scripts seed-dev",
    "test": "echo 'No automated tests. Run `npm run test:integration:all` to run API-tests locally. Run `npm run test:unit:all` to run unit-tests locally.' && exit 0",
    "test:unit:all": "jest --runInBand --config=jest.unit.config.js",
    "test:unit:watch": "npm run test:unit:all -- --watchAll",
    "test:unit:coverage": "npm run test:unit:all -- --coverage --coverageDirectory=coverage/unit",
    "test:integration:local": "node --env-file-if-exists=../.env --require=tsconfig-paths/register --expose-gc node_modules/.bin/jest --config=jest.integration.config.js --runInBand --detectOpenHandles --logHeapUsage",
    "test:integration:base": "node --require=tsconfig-paths/register --expose-gc node_modules/.bin/jest --config=jest.integration.config.js --runInBand --detectOpenHandles --logHeapUsage",
    "test:integration:all": "npm run test:integration:base -- --testPathIgnorePatterns=retry-failed-jobs-on-startup-during-queue-processing.test.ts",
    "test:integration:only-restart-service": "npm run test:integration:base -- retry-failed-jobs-on-startup-during-queue-processing.test.ts",
    "test:integration:debug": "node --inspect-brk=0.0.0.0:9231 --require=tsconfig-paths/register --expose-gc node_modules/.bin/jest --config=jest.integration.config.js --runInBand --detectOpenHandles --logHeapUsage",
    "test:integration:watch": "npm run test:integration:all -- --watchAll",
    "coverage:report:unit": "echo 'This is generated with the test:unit:coverage script.' && exit 1",
    "coverage:report:integration": "nyc report --report-dir coverage/integration --reporter=lcov --reporter=text",
    "coverage:report:combined:merge": "istanbul-merge --out coverage/combined/coverage.json coverage/integration/coverage-final.json coverage/unit/coverage-final.json",
    "coverage:report:combined:generate": "nyc report -t coverage/combined --report-dir coverage/combined --reporter=lcov --reporter=text",
    "coverage:report:combined": "npm run coverage:report:combined:merge && npm run coverage:report:combined:generate",
    "coverage:open:unit": "open coverage/unit/lcov-report/index.html",
    "coverage:open:integration": "open coverage/integration/lcov-report/index.html",
    "coverage:open:combined": "open coverage/combined/lcov-report/index.html",
    "typeorm": "node node_modules/typeorm/cli.js --dataSource=dist/appdatasource.js",
    "migration:create": "node node_modules/typeorm/cli.js migration:create",
    "migration:generate": "npm run typeorm migration:generate",
    "migration:run": "npm run typeorm migration:run",
    "migration:revert": "npm run typeorm migration:revert",
    "test:migration": "npm run typeorm migration:generate src/migration/irrelevant_file_name -- --check",
    "knip": "knip",
    "knip:fix": "knip --fix-type files,exports,types",
    "typecheck": "tsc --noEmit",
    "typecheck:dev": "tsc --noEmit --watch"
  },
  "private": true,
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "dependencies": {
    "@azure/identity": "^4.11.1",
    "@azure/storage-blob": "^12.33.0",
    "@jimp/plugin-print": "^1.6.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/testing": "^11.1.27",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.2",
    "@t3-oss/env-core": "^0.13.11",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "applicationinsights": "^2.9.8",
    "body-parser": "^2.3.0",
    "bull": "^4.16.5",
    "bwip-js": "^2.0.11",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "csv-parser": "^3.2.1",
    "date-fns": "^4.4.0",
    "easy-soap-request": "^5.18.0",
    "form-data": "^4.0.6",
    "ioredis": "^5.11.1",
    "jimp": "^1.6.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "nestjs-paginate": "^12.8.3",
    "nestjs-spelunker": "^1.3.2",
    "openid-client": "^6.1.3",
    "passport": "^0.7.0",
    "passport-azure-ad": "^4.3.5",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.5",
    "ssh2-sftp-client": "^12.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "twilio": "^6.0.2",
    "typeorm": "npm:@global121/typeorm@1.0.4",
    "typescript": "^5.9.3",
    "ufo": "^1.6.4",
    "uuid": "^14.0.1",
    "validator": "^13.15.35",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xml-js": "^1.6.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@automock/adapters.nestjs": "^2.1.0",
    "@automock/jest": "^2.1.2",
    "@nestjs/cli": "^11.0.23",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.x",
    "@types/passport-azure-ad": "^4.3.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-121-platform": "file:../../packages/eslint-config-121-platform/",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "istanbul-merge": "^2.0.0",
    "jest": "^30.4.2",
    "jest-ci-spec-reporter": "^1.0.5",
    "jest-extended": "^7.0.0",
    "knip": "^6.20.0",
    "nodemon": "^3.1.14",
    "nyc": "^18.0.0",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript-eslint": "^8.58.0"
  },
  "overrides": {
    "@nestjs/platform-express": {
      "multer": "2.2.0"
    },
    "@swc/cli": {
      "piscina": "4.9.3"
    }
  }
}
