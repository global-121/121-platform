{
  "name": "mock-service",
  "author": "121.global",
  "homepage": "https://121.global/",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/global-121/121-platform.git",
    "directory": "services/mock-service"
  },
  "private": true,
  "main": "index.js",
  "scripts": {
    "prepare": "npm install --prefix=../../packages/eslint-config-121-platform/",
    "lint": "eslint \"**/*.{ts,js,mjs}\" --cache",
    "fix": "npm run lint -- --fix",
    "test": "npm run lint && npm run typecheck && echo 'No tests available' && exit 0",
    "build": "nest build --path=tsconfig.json",
    "start": "GLOBAL_121_VERSION=$(test -f \"VERSION.txt\" && cat VERSION.txt || echo $GLOBAL_121_VERSION)  node dist/main.js",
    "prestart:dev": "npm install",
    "start:dev": "nest start --require=tsconfig-paths/register --builder=swc --watch --path=tsconfig.json --debug=0.0.0.0:9230",
    "typecheck": "tsc --noEmit",
    "typecheck:dev": "tsc --noEmit --watch"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@nestjs/platform-express": "^11.1.23",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/testing": "^11.1.23",
    "@t3-oss/env-core": "^0.13.11",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "tsconfig-paths": "^4.2.0",
    "ufo": "^1.6.4",
    "uuid": "^14.0.0",
    "xml-js": "^1.6.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.21",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/express": "^4.17.25",
    "@types/node": "^24.x",
    "chokidar": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-121-platform": "file:../../packages/eslint-config-121-platform/",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-regexp": "^3.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
