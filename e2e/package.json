{
  "name": "e2e",
  "author": "121.global",
  "homepage": "https://121.global/",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/global-121/121-platform.git",
    "directory": "e2e"
  },
  "private": true,
  "scripts": {
    "preinstall": "npm install --prefix=../packages/eslint-config-121-platform",
    "postinstall": "npm run install:dependencies-for-portal --prefix=../services/121-service",
    "setup": "npm install && npx playwright install",
    "typecheck": "npx tsc --noEmit",
    "prelint": "npm run typecheck",
    "lint": "eslint \"**/*.{ts,js,mjs}\"",
    "fix": "npm run lint -- --fix",
    "test": "playwright test --config=playwright.config.ts",
    "test:update-snapshots": "npm run test -- --update-snapshots",
    "test:update-snapshots:specific": "npm run test -- --update-snapshots --grep"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.x",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-121-platform": "file:../packages/eslint-config-121-platform/",
    "prettier": "^3.8.1",
    "supertest": "^7.1.4",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "dotenv": "17.3.1",
    "playwright": "^1.58.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  }
}
