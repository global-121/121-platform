{
  "name": "121-platform",
  "author": "121.global",
  "homepage": "https://121.global/",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/global-121/121-platform.git"
  },
  "private": true,
  "workspaces": [
    "packages/eslint-config-121-platform",
    "services/121-service",
    "services/mock-service",
    "interfaces/portal",
    "e2e",
    "tools"
  ],
  "scripts": {
    "start": "echo 'See README.md#getting-started \\n\\n'",
    "start:services": "cd services/ && docker compose --file=docker-compose.yml --file=docker-compose.development.yml up --build",
    "start:services:detach": "npm run start:services -- --detach",
    "start:services:ci": "npm run start:services:detach -- --quiet-pull --wait --wait-timeout 300",
    "start:services:ci:production": "cd services/ && docker --log-level='warn' compose --file=docker-compose.yml up --detach --build --quiet-pull --wait --wait-timeout 300",
    "logs:services": "cd services/ && docker compose logs --follow",
    "start:portal": "npm start -w portal -- --port=8888",
    "start:portal:e2e": "npm run start:debug-production -w portal -- --port=8088",
    "code:portal": "code ./interfaces/portal/",
    "code:121-service": "code ./services/121-service/",
    "code:mock-service": "code ./services/mock-service/",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "fix": "npm run fix --workspaces --if-present",
    "test": "echo 'See README.md#testing \\n\\n' && npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  }
}
