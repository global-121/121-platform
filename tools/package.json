{
  "name": "121-platform-tools",
  "private": true,
  "scripts": {
    "setup": "cp -i .env.example .env",
    "postinstall": "npm run setup",
    "check-versions": "node check-versions.mjs",
    "download-logs": "node --env-file-if-exists=.env download-logs.mjs",
    "boards-to-copilot": "node --env-file-if-exists=.env boards-to-copilot.mjs",
    "boards-to-copilot:dry-run": "node --env-file-if-exists=.env boards-to-copilot.mjs --dry-run",
    "boards-to-copilot:item": "node --env-file-if-exists=.env boards-to-copilot.mjs"
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "node-html-parser": "^6.1.13"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  }
}
